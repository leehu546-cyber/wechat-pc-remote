{
  "ollamaUrl": "http://127.0.0.1:11434",
  "model": "qwen2.5:7b",
  "agentMode": true,
  "systemPrompt": "你是一个简洁友好的中文助手。回答要简短清楚，适合在手机微信里阅读。",
  "maxHistory": 20,
  "maxAgentTurns": 8,
  "commandTimeoutSec": 120,
  "maxOutputChars": 4000,
  "workDir": "D:\\cursor\\61",
  "notifyEachCommand": false,
  "notifyOnStart": true,
  "startMessage": "处理中…",
  "resultOnly": true,
  "maxReplyChars": 120,
  "auditLog": true,
  "taskClassification": {
    "simpleThreshold": 3,
    "complexThreshold": 3,
    "ambiguousMargin": 1,
    "stripPrefixes": ["给我", "帮我", "请", "麻烦", "能不能", "可以"]
  },
  "cliRouting": {
    "cliTimeoutSec": 300,
    "opencode": {
      "model": "opencode/deepseek-v4-flash-free",
      "serveUrl": "http://127.0.0.1:4096",
      "servePort": 4096,
      "requireServe": true
    }
  },
  "serveWatchdogSec": 300
}
